# Server
PORT=3001
# Optional explicit backend port override (takes precedence over PORT)
BACKEND_PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
# Optional: absolute path to built frontend dist for single-server deploys
FRONTEND_DIST_PATH=../app/dist

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/saheli

# JWT Secret
JWT_SECRET=your-jwt-secret-here

# Algorand (required for strict blockchain mode)
ALGORAND_STRICT_MODE=true
ALGORAND_NETWORK=testnet
ALGORAND_TREASURY_MNEMONIC=
ALGORAND_MICROALGOS_PER_RUPEE=1000

# Optional Algod client overrides (defaults point to Algonode for selected network)
ALGORAND_ALGOD_SERVER=https://testnet-api.algonode.cloud
ALGORAND_ALGOD_PORT=443
ALGORAND_ALGOD_TOKEN=
ALGORAND_ALGOD_TOKEN_HEADER=X-Algo-API-Token
ALGORAND_ALGOD_HEADERS=

# Optional Indexer client overrides
ALGORAND_INDEXER_SERVER=https://testnet-idx.algonode.cloud
ALGORAND_INDEXER_PORT=443
ALGORAND_INDEXER_TOKEN=
ALGORAND_INDEXER_TOKEN_HEADER=X-Algo-API-Token
ALGORAND_INDEXER_HEADERS=

# OpenAI (optional — for live AI responses)
OPENAI_API_KEY=sk-your-key-here
# Optional OpenAI chat model for free-form WhatsApp queries
OPENAI_CHAT_MODEL=gpt-4o-mini

# Sarvam AI Translation (for website localization)
SARVAM_API_KEY=your-sarvam-api-key
# Optional; keep default unless your Sarvam endpoint is different
SARVAM_API_URL=https://api.sarvam.ai/translate
# Optional; set to authorization if your key must be sent as Bearer token
SARVAM_API_KEY_HEADER=api-subscription-key
# Optional application identifier for Sarvam headers
SARVAM_APP_ID=

# Twilio WhatsApp (optional)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# Preferred key (falls back to TWILIO_WHATSAPP_NUMBER)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Optional: use Messaging Service instead of explicit From
TWILIO_MESSAGING_SERVICE_SID=
# Validate incoming Twilio signatures (recommended true in production)
TWILIO_VALIDATE_SIGNATURE=true
# Public HTTPS base URL used to validate webhook signatures, e.g. https://abc123.ngrok.io
PUBLIC_BASE_URL=
# Optional explicit status callback URL (defaults to PUBLIC_BASE_URL + /webhook/twilio/status)
TWILIO_STATUS_CALLBACK_URL=
# Optional WhatsApp approved template sid (for business-initiated messages)
TWILIO_WHATSAPP_CONTENT_SID=

# QR Code Storage (optional — uses base64 by default)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Optional unsigned upload preset (if set, API key/secret are not required for upload)
CLOUDINARY_UPLOAD_PRESET=your-upload-preset
# Optional upload folder
CLOUDINARY_FOLDER=saheli/qr-proofs

# DeFi Adapter Runtime Controls (safe defaults)
DEFI_ENABLED=true
DEFI_LIVE_MODE=false
DEFI_EMERGENCY_STOP=false
DEFI_PROVIDER=simulated
DEFI_MAX_DEPLOYMENT_RUPEES=50000
DEFI_MIN_IDLE_BUFFER_RUPEES=5000
DEFI_ALLOWED_PROTOCOLS=Folks Finance,Tinyman,Pact

# Folks live adapter (required only when DEFI_PROVIDER=folks and DEFI_LIVE_MODE=true)
DEFI_FOLKS_API_URL=
DEFI_FOLKS_API_KEY=
